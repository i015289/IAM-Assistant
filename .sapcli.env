# sapcli connection configuration for ER6
# Source this file before running sapcli: source .sapcli.env

export SAP_ASHOST='er6-001-adm.wdf.sap.corp'
export SAP_PORT='443'
export SAP_SYSNR='00'
export SAP_CLIENT='100'
export SAP_USER='ANZEIGER'
export SAP_PASSWORD='display'
export SAP_SSL='yes'
export SAP_SSL_VERIFY='no'
