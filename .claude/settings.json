{
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(git pull)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "mcp__er6__query_sql",
      "mcp__er6__read_table_def",
      "mcp__er6__read_cds_view",
      "mcp__er6__read_class",
      "mcp__er6__read_program",
      "mcp__er6__list_package",
      "mcp__sap-wiki__general_search",
      "mcp__sap-wiki__cql_search",
      "mcp__sap-wiki__cql_examples",
      "mcp__sap-wiki__wiki_content",
      "mcp__sap-wiki__wiki_create_page",
      "mcp__sap-wiki__wiki_get_page_for_edit",
      "mcp__sap-wiki__wiki_update_page"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-memo.sh",
            "statusMessage": "Validating memo structure..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/sync-skills.sh",
            "statusMessage": "Syncing skill to skills/ and commands/..."
          }
        ]
      },
      {
        "matcher": "mcp__er6__query_sql",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-query.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
